{
  "enabled": true,
  "default_action": "deny",
  "tool_timeout_seconds": 20,
  "max_tool_output_chars": 12000,
  "audit_log_enabled": true,

  "allowed_roots": [
    "D:\\side_project\\auto_gpt"
  ],

  "argument_guards": {
    "blocked_path_patterns": [
      "**/.env",
      "**/.git/**",
      "**/Cookies",
      "**/Local State",
      "**/edge_debug_profile/**",
      "**/browser_profile/**",
      "**/auth_state.json",
      "**/id_rsa",
      "**/id_ed25519",
      "**/*.pem",
      "**/*.key"
    ],
    "blocked_command_patterns": [
      "powershell*",
      "pwsh*",
      "cmd*",
      "bash*",
      "sh*",
      "curl*",
      "wget*",
      "iwr*",
      "irm*",
      "rm *",
      "del *",
      "rmdir *",
      "format *",
      "git push*",
      "git config*",
      "npm publish*"
    ],
    "blocked_env_keys": [
      "*TOKEN*",
      "*SECRET*",
      "*KEY*",
      "*PASSWORD*",
      "*COOKIE*"
    ]
  },

  "tool_policies": [
    {
      "pattern": "filesystem__read_text_file",
      "action": "allow",
      "reason": "Read-only text file access inside allowed roots"
    },
    {
      "pattern": "filesystem__read_file",
      "action": "allow",
      "reason": "Read-only file access inside allowed roots"
    },
    {
      "pattern": "filesystem__list_directory",
      "action": "allow",
      "reason": "Directory listing inside allowed roots"
    },
    {
      "pattern": "filesystem__list_allowed_directories",
      "action": "allow",
      "reason": "Read-only allowed directory listing"
    },
    {
      "pattern": "filesystem__directory_tree",
      "action": "allow",
      "reason": "Directory tree listing inside allowed roots"
    },
    {
      "pattern": "filesystem__search_files",
      "action": "allow",
      "reason": "File search inside allowed roots"
    },
    {
      "pattern": "filesystem__get_file_info",
      "action": "allow",
      "reason": "Read-only metadata access"
    },
    {
      "pattern": "filesystem__write_file",
      "action": "confirm",
      "reason": "Writing files requires explicit confirmation"
    },
    {
      "pattern": "filesystem__edit_file",
      "action": "confirm",
      "reason": "Editing files requires explicit confirmation"
    },
    {
      "pattern": "filesystem__create_directory",
      "action": "confirm",
      "reason": "Creating directory requires explicit confirmation"
    },
    {
      "pattern": "filesystem__move_file",
      "action": "confirm",
      "reason": "Moving files requires explicit confirmation"
    },
    {
      "pattern": "filesystem__delete_file",
      "action": "deny",
      "reason": "Deleting files is denied"
    },
    {
      "pattern": "filesystem__remove_directory",
      "action": "deny",
      "reason": "Deleting directories is denied"
    },
    {
      "pattern": "filesystem__*",
      "action": "deny",
      "reason": "Unlisted filesystem tool denied by default"
    }
  ]
}