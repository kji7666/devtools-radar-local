{
  "name": "auto-gpt-local-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "productName": "Auto GPT Local UI",
  "description": "Local ChatGPT automation desktop UI",
  "author": "local",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vue-tsc -b && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && npx electron-builder --win portable --x64",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "vite": "latest",
    "vue": "latest",
    "wait-on": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "vue-tsc": "latest"
  },
  "build": {
    "appId": "local.autogpt.ui",
    "productName": "Auto GPT Local UI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "AutoGPT-Local-UI.exe"
    }
  }
}