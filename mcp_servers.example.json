{
  "servers": {
    "filesystem": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\side_project\\auto_gpt"
      ],
      "env": {},

      "risk_level": "low",
      "trust": "trusted",
