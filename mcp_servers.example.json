      "notes": "Filesystem MCP scoped to project root. Change path after cloning."
    },

    "remote_example": {
      "enabled": false,
      "transport": "streamable_http",
      "url": "http://127.0.0.1:3000/mcp",
      "headers": {},
      "timeout_seconds": 30,

      "risk_level": "medium",
      "trust": "unreviewed",
      "network": "unknown",
      "filesystem": "unknown",
      "shell": "deny",
      "auto_approve": false,
      "notes": "Example Streamable HTTP MCP server."
    }
  }
}